# Flashcred Server Environment Variables Template
# Copy this file to .env and fill in the actual values

# Server Port
PORT=3001

# Database Configuration (Raw MySQL Connection)
DB_HOST=localhost
DB_USER=root
DB_PASS=your_db_password
DB_NAME=flashcred

# Encryption key for bank credentials (AES-256-GCM)
# IMPORTANT: This must be a 64-character hex string (32 bytes)
# Do not change this after credentials have been saved, or they will be unreadable.
ENCRYPTION_KEY=e0ae14a45ca6732ec2d27cf53858a8f89e9495aeac8b14689bbc615c5eabaeee

# Optional: RPA Settings
# HEADLESS=true
